SERVER_CHECKER_DATABASE_URL=mysql://root:your_password@127.0.0.1:3306/server_checker

# Or use split MYSQL_* variables instead of SERVER_CHECKER_DATABASE_URL
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=server_checker

# Web login credentials can be wired explicitly with username_env/password_env
# in configs/hosts.yaml, or by using target-based names automatically.
# Example for target name "merchant_portal":
# MERCHANT_PORTAL_USERNAME=your_username
# MERCHANT_PORTAL_PASSWORD=your_password
